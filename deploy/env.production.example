PORT=3001
NODE_ENV=production
APP_NAME=Čisto
JWT_SECRET=replace-with-strong-access-secret
REFRESH_TOKEN_SECRET=replace-with-strong-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

DATA_MODE=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_SSL=true

PAYMENT_MODE=stripe
STRIPE_PUBLIC_KEY=pk_live_or_test_replace
STRIPE_SECRET_KEY=sk_live_or_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
STRIPE_CURRENCY=rsd

STORAGE_MODE=cloudinary
CLOUDINARY_CLOUD_NAME=replace
CLOUDINARY_UPLOAD_PRESET=replace
CLOUDINARY_API_KEY=replace
CLOUDINARY_API_SECRET=replace
CLOUDINARY_FOLDER=cisto/providers

CORS_ORIGIN=https://your-domain.example
SITE_URL=https://your-domain.example
TRUST_PROXY=true
LOG_LEVEL=info
